# Lostify production environment — copy to .env on EC2
# cp .env.example .env && nano .env

JWT_SECRET_KEY=change-me-to-a-long-random-string
LOG_LEVEL=INFO

# Optional: PostgreSQL (Phase 5 Step 3)
# DATABASE_URL=postgresql://lostify:password@your-rds-endpoint:5432/lostify

# EC2 only — set to your public IP for frontend API URLs
# PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP

# Auto-trigger Step Functions on claim submit/approve/reject (optional)
STEP_FUNCTIONS_STATE_MACHINE_ARN=arn:aws:states:eu-central-1:ACCOUNT_ID:stateMachine:LostifyClaimRecoverySaga
AWS_REGION=eu-central-1
# Use EC2 instance IAM role (recommended) OR set keys below for item-service container
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
